{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": ["@types", "./node_modules/@types"],
    "paths": {
      "@controllers/*": ["./controllers/*"],
      "@models/*": ["./models/*"],
      "@routes/*": ["./routes/*"],
      "@utils/*": ["./utils/*"],
      "@views/*": ["./views/*"],
      "@socket/*": ["./socket/*"],
      "@jobs/*": ["./jobs/*"],
      "@server": ["./server.ts"]
    }
  },
  "include": ["**/*.ts"]
}
